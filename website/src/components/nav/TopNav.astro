---
import { nav, site } from '~/lib/site';

const path = Astro.url.pathname;
---

<header
  class="sticky top-0 z-40 backdrop-blur"
  style="background: color-mix(in srgb, var(--color-bg) 92%, transparent)"
>
  <div class="container-page hairline flex h-14 items-center justify-between border-b">
    <a
      href="/"
      class="flex items-center gap-2 font-medium tracking-tight"
      style="color: var(--color-fg)"
    >
      <span
        class="inline-block h-6 w-6 rounded"
        style="background: var(--color-primary)"
        aria-hidden></span>
      <span class="font-serif text-lg">{site.name}</span>
    </a>
    <nav class="flex items-center gap-6 text-sm">
      {
        nav.top.map((item) => {
          const active = !('external' in item && item.external) && path.startsWith(item.href);
          return (
            <a
              href={item.href}
              class="transition-opacity hover:opacity-70"
              style={`color: ${active ? 'var(--color-primary)' : 'var(--color-fg)'}`}
              {...('external' in item && item.external
                ? { target: '_blank', rel: 'noopener' }
                : {})}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>
  </div>
</header>
